---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Faatikh Riziq`} description={description}>
  <article class="blog-post section">
    <div class="container">
      <header class="blog-post__header">
        <div class="blog-post__meta">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="blog-post__divider">|</span>
          <div class="blog-post__tags">
            {tags.map((tag) => (
              <span class="blog-post__tag">#{tag}</span>
            ))}
          </div>
        </div>
        <h1 class="blog-post__title">{title}</h1>
        <p class="blog-post__desc">{description}</p>
      </header>
      <div class="blog-post__content">
        <slot />
      </div>
      <footer class="blog-post__footer">
        <a href="/blog" class="blog-post__back">&larr; Back to all posts</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post__header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .blog-post__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-bottom: 1rem;
  }

  .blog-post__divider {
    color: var(--border);
  }

  .blog-post__tags {
    display: flex;
    gap: 0.5rem;
  }

  .blog-post__tag {
    color: var(--accent);
  }

  .blog-post__title {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .blog-post__desc {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  .blog-post__content {
    max-width: 720px;
  }

  .blog-post__content :global(h2) {
    font-size: 1.375rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content :global(h3) {
    font-size: 1.125rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  .blog-post__content :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.7;
  }

  .blog-post__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .blog-post__content :global(pre) {
    margin-bottom: 1.5rem;
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .blog-post__footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .blog-post__back {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .blog-post__title {
      font-size: 1.5rem;
    }
  }
</style>
