---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  </head>
  <body>
    <Header />
    <main id="main" style={`padding-top: var(--header-height)`}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
