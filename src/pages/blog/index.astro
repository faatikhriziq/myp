---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const sectionLabel = 'mb-3 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.22em] text-amber';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://faatikhriziq.my.id';
const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Faatikh Riziq Blog',
  url: `${siteUrl}/blog/`,
  description: 'Thoughts on software engineering, system design, architecture decisions, and lessons from building production systems.',
  author: {
    '@type': 'Person',
    name: 'Faatikh Riziq',
  },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    url: `${siteUrl}/blog/${post.id}/`,
  })),
};
---

<BaseLayout
  title="Blog — Faatikh Riziq"
  description="Thoughts on software engineering, system design, architecture decisions, and lessons from building production systems."
  jsonLd={blogJsonLd}
>
  <section class="py-20 sm:py-28">
    <div class="mx-auto w-full max-w-4xl px-6 sm:px-8">
      <div data-reveal>
        <span class={sectionLabel}><span class="text-subtle">//</span>Blog</span>
        <h1 class="mb-5 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">Writing</h1>
        <p class="mb-10 max-w-2xl text-base leading-8 text-muted">
          Notes on engineering decisions, system design, and things I learn along the way.
        </p>
      </div>
      {posts.length === 0 ? (
        <p class="font-mono text-sm text-subtle">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
