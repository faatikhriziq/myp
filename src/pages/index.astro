---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import TechBadge from '../components/TechBadge.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const techStack = [
  'Go', 'TypeScript', 'Python', 'PostgreSQL', 'Redis',
  'Docker', 'Git', 'Linux', 'gRPC', 'REST',
  'PostGIS', 'CI/CD', 'Terraform', 'Astro',
];

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Faatikh Riziq',
  url: 'https://faatikhriziq.my.id',
  jobTitle: 'Software Engineer',
  description: 'Software engineer focused on building reliable, well-architected systems.',
  sameAs: [
    'https://github.com/faatikhriziq',
    'https://linkedin.com/in/faatikhriziq',
    'https://x.com/faatikhriziq',
  ],
  knowsAbout: ['Software Architecture', 'System Design', 'Go', 'PostgreSQL', 'Backend Engineering'],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Faatikh Riziq',
  url: 'https://faatikhriziq.my.id',
  description: 'Portfolio and blog about software engineering, backend systems, and architecture.',
  author: {
    '@type': 'Person',
    name: 'Faatikh Riziq',
  },
};

const buttonBase = 'inline-flex items-center justify-center rounded-full px-5 py-3 font-mono text-sm font-semibold transition duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber focus-visible:ring-offset-2 focus-visible:ring-offset-canvas';
const primaryButton = `${buttonBase} bg-amber text-canvas shadow-lg shadow-amber/20 hover:-translate-y-0.5 hover:bg-[#ffd16a]`;
const outlineButton = `${buttonBase} border border-white/15 bg-white/5 text-ink backdrop-blur hover:-translate-y-0.5 hover:border-amber/45 hover:text-amber`;
const sectionLabel = 'mb-3 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.22em] text-amber';
const sectionTitle = 'mb-8 text-3xl font-semibold tracking-tight text-ink sm:text-4xl';
---

<BaseLayout
  title="Faatikh Riziq — Software Engineer"
  description="Software engineer focused on building reliable, well-architected systems. Experienced in production-grade backend systems, system design, and software architecture."
  jsonLd={[personJsonLd, websiteJsonLd]}
>
  <section class="relative isolate flex min-h-[calc(100dvh-4rem)] items-center overflow-hidden py-20 sm:py-24">
    <div class="absolute left-1/2 top-16 -z-10 h-40 w-[min(48rem,86vw)] -translate-x-1/2 rounded-full bg-gradient-to-r from-amber/20 via-cyan/10 to-mint/15 blur-3xl"></div>
    <div class="mx-auto grid w-full max-w-6xl items-center gap-12 px-6 sm:px-8 lg:grid-cols-[minmax(0,1fr)_430px]">
      <div data-reveal data-reveal-delay="0">
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 font-mono text-xs text-muted shadow-lg shadow-black/10 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-mint shadow-[0_0_16px_rgba(101,230,164,0.8)]"></span>
          Backend systems, architecture, and product engineering
        </div>
        <p class="mb-3 font-mono text-sm text-amber">Hi, I'm</p>
        <h1 class="max-w-4xl bg-gradient-to-br from-white via-ink to-amber bg-clip-text text-5xl font-semibold leading-[1.02] tracking-[-0.05em] text-transparent sm:text-6xl lg:text-7xl">
          Muhammad Ali Faatikh Riziq
        </h1>
        <p class="mt-5 font-mono text-base text-cyan sm:text-lg">Software Engineer</p>
        <p class="mt-5 max-w-2xl text-base leading-8 text-muted sm:text-lg">
          I build systems with clear boundaries, reliable contracts, and
          architecture that holds up under real-world pressure.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#projects" class={primaryButton}>View Projects</a>
          <a href="/blog" class={outlineButton}>Read Blog</a>
        </div>
        <dl class="mt-10 grid max-w-xl grid-cols-3 gap-3">
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
            <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-subtle">Focus</dt>
            <dd class="mt-2 text-sm font-semibold text-ink">Backend</dd>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
            <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-subtle">Stack</dt>
            <dd class="mt-2 text-sm font-semibold text-ink">Go + TS</dd>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
            <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-subtle">Domain</dt>
            <dd class="mt-2 text-sm font-semibold text-ink">Systems</dd>
          </div>
        </dl>
      </div>
      <div class="hidden lg:block" data-reveal data-reveal-delay="160">
        <TerminalHero />
      </div>
    </div>
  </section>

  <section id="about" class="py-20 sm:py-28">
    <div class="mx-auto w-full max-w-6xl px-6 sm:px-8">
      <span class={sectionLabel}><span class="text-subtle">//</span>About</span>
      <h2 class={sectionTitle}>Background</h2>
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-2xl shadow-black/10 backdrop-blur sm:p-8" data-reveal>
          <div class="space-y-5 text-base leading-8 text-muted">
            <p>
            I'm a software engineer with hands-on experience building production-grade systems — 
            including an ERP platform with modular monolith architecture, event-driven messaging, 
            and schema-level isolation in PostgreSQL.
            </p>
            <p>
            My core interest lies in system design, software architecture, and building 
            data-intensive applications that are maintainable at scale. I think deeply about 
            boundaries, contracts, and trade-offs — not just which framework is trending this week.
            </p>
            <p>
            I'm currently growing toward a more senior engineering role, with a focus on 
            server-side and systems work — while keeping my skills broad enough to build 
            end-to-end when needed.
            </p>
          </div>
          <p class="mt-6 border-t border-white/10 pt-5 text-sm italic leading-7 text-subtle">
            Outside of engineering, I'm training for a marathon. Endurance sports and 
            software have more in common than you'd think — both reward consistency 
            over intensity.
          </p>
        </div>
        <aside class="rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.08] to-white/[0.025] p-6 shadow-2xl shadow-black/10 backdrop-blur sm:p-7" data-reveal data-reveal-delay="120">
          <div class="mb-5 flex items-center justify-between gap-4">
            <h3 class="font-mono text-sm text-muted">Tech I work with</h3>
            <span class="rounded-full bg-mint/10 px-3 py-1 font-mono text-[0.7rem] text-mint">active stack</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <TechBadge name={tech} />
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section id="projects" class="py-20 sm:py-28">
    <div class="mx-auto w-full max-w-6xl px-6 sm:px-8">
      <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end" data-reveal>
        <div>
          <span class={sectionLabel}><span class="text-subtle">//</span>Projects</span>
          <h2 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Selected Work</h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-muted">
          Practical systems work with emphasis on boundaries, data integrity, and operational simplicity.
        </p>
      </div>
      <div class="grid gap-5 lg:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            stack={project.stack}
            highlights={project.highlights}
            href={`/projects/${project.slug}`}
            linkLabel="Read case study"
          />
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 sm:py-28">
    <div class="mx-auto w-full max-w-6xl px-6 sm:px-8">
      <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-white/[0.09] via-white/[0.045] to-[rgba(246,185,68,0.08)] p-6 shadow-2xl shadow-black/20 backdrop-blur sm:p-10" data-reveal>
        <div class="absolute right-0 top-0 h-48 w-48 translate-x-1/3 -translate-y-1/3 rounded-full bg-amber/20 blur-3xl"></div>
        <div class="relative">
          <span class={sectionLabel}><span class="text-subtle">//</span>Contact</span>
          <h2 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Get in Touch</h2>
          <p class="max-w-2xl text-base leading-8 text-muted">
            I'm open to interesting conversations about engineering, architecture, 
            or collaboration opportunities. Reach out via email or connect on socials.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="mailto:hello@faatikhriziq.my.id" class={primaryButton}>Send Email</a>
            <a href="https://github.com/faatikhriziq" class={outlineButton} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://linkedin.com/in/faatikhriziq" class={outlineButton} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
