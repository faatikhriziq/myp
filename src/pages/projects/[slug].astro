---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://faatikhriziq.my.id';

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.description,
  url: `${siteUrl}/projects/${project.slug}/`,
  author: {
    '@type': 'Person',
    name: 'Faatikh Riziq',
  },
  keywords: project.stack.join(', '),
};

const sectionLabel = 'mb-3 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.22em] text-amber';
---

<BaseLayout
  title={`${project.title} Case Study — Faatikh Riziq`}
  description={project.description}
  canonicalUrl={`${siteUrl}/projects/${project.slug}/`}
  jsonLd={projectJsonLd}
>
  <article class="py-20 sm:py-28">
    <div class="mx-auto w-full max-w-6xl px-6 sm:px-8">
      <header class="mb-12 border-b border-white/10 pb-10" data-reveal>
        <a href="/#projects" class="mb-8 inline-flex font-mono text-sm text-amber transition hover:text-ink">&larr; Back to projects</a>
        <span class={sectionLabel}><span class="text-subtle">//</span>Case Study</span>
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
          <div>
            <h1 class="max-w-4xl text-4xl font-semibold leading-tight tracking-tight text-ink sm:text-6xl">{project.title}</h1>
            <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">{project.subtitle}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
            {project.metrics.map((metric) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
                <p class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-subtle">{metric.label}</p>
                <p class="mt-2 text-sm font-semibold text-ink">{metric.value}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="mt-8 flex flex-wrap gap-2">
          {project.stack.map((tech) => (
            <TechBadge name={tech} />
          ))}
        </div>
      </header>

      <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
        <div class="space-y-12">
          <section id="context" class="scroll-mt-28 rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-2xl shadow-black/10 backdrop-blur sm:p-8" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">01</span>Context</span>
            <p class="text-base leading-8 text-muted">{project.context}</p>
          </section>

          <section id="problem" class="scroll-mt-28 rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-2xl shadow-black/10 backdrop-blur sm:p-8" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">02</span>Problem</span>
            <p class="text-base leading-8 text-muted">{project.problem}</p>
          </section>

          <section id="architecture" class="scroll-mt-28" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">03</span>Architecture</span>
            <div class="grid gap-4 md:grid-cols-2">
              {project.architecture.map((node, index) => (
                <div class="relative rounded-3xl border border-white/10 bg-white/[0.045] p-6 backdrop-blur">
                  <div class="mb-4 flex items-center gap-3">
                    <span class="grid h-9 w-9 place-items-center rounded-full border border-amber/20 bg-amber/10 font-mono text-xs text-amber">{index + 1}</span>
                    <h2 class="text-lg font-semibold text-ink">{node.label}</h2>
                  </div>
                  <p class="text-sm leading-7 text-muted">{node.description}</p>
                </div>
              ))}
            </div>
          </section>

          <section id="approach" class="scroll-mt-28 rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-2xl shadow-black/10 backdrop-blur sm:p-8" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">04</span>Approach</span>
            <ul class="grid gap-3" role="list">
              {project.approach.map((item) => (
                <li class="relative pl-7 text-base leading-7 text-muted before:absolute before:left-0 before:top-0 before:font-mono before:text-sm before:leading-7 before:text-mint before:content-['>']">{item}</li>
              ))}
            </ul>
          </section>

          <section id="decisions" class="scroll-mt-28" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">05</span>Key Decisions</span>
            <div class="grid gap-4">
              {project.decisions.map((decision) => (
                <div class="rounded-3xl border border-white/10 bg-white/[0.045] p-6 backdrop-blur">
                  <h2 class="text-lg font-semibold text-ink">{decision.title}</h2>
                  <p class="mt-3 text-sm leading-7 text-muted">{decision.body}</p>
                </div>
              ))}
            </div>
          </section>

          <section id="tradeoffs" class="scroll-mt-28" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">06</span>Trade-offs</span>
            <div class="grid gap-4 md:grid-cols-2">
              {project.tradeoffs.map((tradeoff) => (
                <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.06] to-white/[0.025] p-6 backdrop-blur">
                  <h2 class="text-lg font-semibold text-ink">{tradeoff.title}</h2>
                  <p class="mt-3 text-sm leading-7 text-muted">{tradeoff.body}</p>
                </div>
              ))}
            </div>
          </section>

          <section id="lessons" class="scroll-mt-28 rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.09] via-white/[0.045] to-[rgba(246,185,68,0.08)] p-6 shadow-2xl shadow-black/20 backdrop-blur sm:p-8" data-reveal>
            <span class={sectionLabel}><span class="text-subtle">07</span>Lessons Learned</span>
            <ul class="grid gap-3" role="list">
              {project.lessons.map((lesson) => (
                <li class="relative pl-7 text-base leading-7 text-muted before:absolute before:left-0 before:top-0 before:font-mono before:text-sm before:leading-7 before:text-amber before:content-['//']">{lesson}</li>
              ))}
            </ul>
          </section>
        </div>

        <aside class="sticky top-24 hidden self-start lg:block" data-reveal data-reveal-delay="140">
          <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-5 backdrop-blur">
            <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-subtle">Case study</p>
            <div class="flex flex-col gap-3 text-sm leading-6 text-muted">
              <a class="transition hover:text-amber" href="#context">Context</a>
              <a class="transition hover:text-amber" href="#architecture">Architecture</a>
              <a class="transition hover:text-amber" href="#decisions">Decisions</a>
              <a class="transition hover:text-amber" href="#lessons">Lessons</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
