---
const lines = [
  '$ whoami',
  'faatikh-riziq',
  '$ cat role.txt',
  'Software Engineer',
  '$ grep -r "passion" ./life',
  'Building systems that scale.',
];
---

<div class="relative w-full max-w-[480px] overflow-hidden rounded-3xl border border-white/10 bg-[#09101d]/85 font-mono text-xs shadow-2xl shadow-cyan/10 backdrop-blur" aria-hidden="true">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_0%,rgba(103,215,255,0.18),transparent_36%)]"></div>
  <div class="relative flex items-center gap-1.5 border-b border-white/10 bg-white/[0.04] px-4 py-3">
    <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
    <span class="ml-2 text-[0.7rem] text-subtle">~/faatikhriziq</span>
  </div>
  <div class="relative min-h-44 p-5">
    {lines.map((line, i) => (
      <div
        class:list={[
          'mb-1.5 animate-terminal-fade-in opacity-0 leading-7',
          { 'text-ink': line.startsWith('$') },
          { 'text-amber': !line.startsWith('$') },
        ]}
        style={`animation-delay: ${i * 0.4}s`}
      >
        {line.startsWith('$') ? (
          <>
            <span class="mr-2 select-none text-mint">$</span>
            <span>{line.slice(2)}</span>
          </>
        ) : (
          <span>{line}</span>
        )}
      </div>
    ))}
    <div class="animate-terminal-fade-in opacity-0" style={`animation-delay: ${lines.length * 0.4}s`}>
      <span class="mr-2 select-none text-mint">$</span>
      <span class="animate-blink text-ink">_</span>
    </div>
  </div>
</div>
