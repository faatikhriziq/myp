---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="inline-flex whitespace-nowrap rounded-full border border-amber/20 bg-amber/10 px-3 py-1 font-mono text-xs font-medium text-amber shadow-[0_0_24px_rgba(246,185,68,0.08)] transition duration-200 hover:border-amber/55 hover:bg-amber/15">
  {name}
</span>
