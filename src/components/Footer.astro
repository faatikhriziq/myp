---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/faatikhriziq', label: 'GitHub', icon: 'github' },
  { href: 'https://linkedin.com/in/faatikhriziq', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'mailto:hello@faatikhriziq.my.id', label: 'Email', icon: 'email' },
  { href: 'https://x.com/faatikhriziq', label: 'X/Twitter', icon: 'twitter' },
];
---

<footer class="relative z-10 mt-auto border-t border-white/10 bg-canvas/45 py-8 backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-5 px-6 text-center sm:px-8 md:flex-row md:text-left">
    <div>
      <span class="font-mono text-xs text-muted">
        <span class="text-mint">$</span> echo &copy; {currentYear} Faatikh Riziq
      </span>
    </div>
    <nav class="flex flex-wrap justify-center gap-3" aria-label="Social links">
      {socialLinks.map(({ href, label }) => (
        <a
          href={href}
          class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 font-mono text-xs text-muted transition hover:border-amber/45 hover:text-amber"
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          aria-label={label}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>
