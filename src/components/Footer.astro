---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/faatikhriziq', label: 'GitHub', icon: 'github' },
  { href: 'https://linkedin.com/in/faatikhriziq', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'mailto:hello@faatikhriziq.my.id', label: 'Email', icon: 'email' },
  { href: 'https://x.com/faatikhriziq', label: 'X/Twitter', icon: 'twitter' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <span class="footer__copyright">
        <span class="footer__prompt">$</span> echo &copy; {currentYear} Faatikh Riziq
      </span>
    </div>
    <nav class="footer__links" aria-label="Social links">
      {socialLinks.map(({ href, label }) => (
        <a
          href={href}
          class="footer__link"
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          aria-label={label}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: auto;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__copyright {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .footer__prompt {
    color: var(--terminal-green);
  }

  .footer__links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
