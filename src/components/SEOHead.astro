---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalUrl,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://faatikhriziq.my.id';
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const resolvedCanonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const isoDate = (date: Date | string) => (date instanceof Date ? date : new Date(date)).toISOString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Faatikh Riziq" />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="format-detection" content="telephone=no" />
<meta name="color-scheme" content="dark" />
<link rel="canonical" href={resolvedCanonical} />
<link rel="icon" type="image/svg+xml" href="/logo.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="alternate" type="application/rss+xml" title="Faatikh Riziq Blog" href={`${siteUrl}/rss.xml`} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={`${title} preview image`} />
<meta property="og:site_name" content="Faatikh Riziq" />
<meta property="og:locale" content="en_US" />
{publishedTime && <meta property="article:published_time" content={isoDate(publishedTime)} />}
{modifiedTime && <meta property="article:modified_time" content={isoDate(modifiedTime)} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={`${title} preview image`} />
<meta name="twitter:creator" content="@faatikhriziq" />
<meta name="theme-color" content="#070a12" />
{jsonLdItems.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}
