---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  ogImage?: string;
}

const { title, description, pubDate, tags, slug, ogImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block overflow-hidden rounded-3xl border border-white/10 bg-white/[0.045] shadow-xl shadow-black/10 backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-amber/45 hover:bg-white/[0.07]" data-reveal data-blog-card data-title={title.toLowerCase()} data-tags={tags.join(',').toLowerCase()} data-description={description.toLowerCase()}>
  <article>
    {ogImage && (
      <div class="aspect-[1200/630] w-full overflow-hidden border-b border-white/10">
        <img
          src={ogImage}
          alt={title}
          width="1200"
          height="630"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-6">
      <div class="mb-4 flex flex-wrap items-center gap-2 font-mono text-xs text-subtle">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="text-white/15">/</span>
        <div class="flex flex-wrap gap-2">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-muted">{tag}</span>
          ))}
        </div>
      </div>
      <h3 class="mb-2 text-lg font-semibold tracking-tight text-ink transition group-hover:text-amber">{title}</h3>
      <p class="line-clamp-2 text-sm leading-6 text-muted">{description}</p>
    </div>
  </article>
</a>
